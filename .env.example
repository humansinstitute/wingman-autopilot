# STARTING PORT FOR AGENT PORTS
AGENT_PORTS=3700
## How many concurrent ports and session can we run
AGENT_MAX=21
# Default agent for AI features (Edit with AI, Fix with AI, quick launch)
# Options: codex, claude, goose, opencode, gemini
# DEFAULT_AGENT=codex
# AGENT_SPAWN_MODE=bun
# AGENT_SPAWN_MODE=tmux
# AGENT_TMUX_SESSION=wm-ap-agents
IDENTITY_SESSION_SECRET=

# Port for the main Webapp
PORT=3021
# Start Directory
DIRECTORY_DEF='~/code'
# ALLOWED FOLDERS FOR ACCESSS - THIS WILL RESTRICT WINGMAN TO ONLY SHOW THE FOLLOWING FOLDERS IN FILE BROWSERS
FOLDERACCESS=~/code,~/Documents,~/Wingman

AGENTAPI_ALLOWED_HOSTS="localhost,127.0.0.1,[::1]"

# TRIGGERS  Details for triggering agent sessions programatically.

# SET ADMIN NPUB(S) FOR SIMPLE SETUP AND FREE CREDITS
# Use a comma-separated list for multiple admins: npub1...,npub1...
ADMIN_NPUB=

# Docker-first setup uses instance env files such as .env.wingman-01.
# Keep this .env file for local `bun start` development. Prefer generating Docker env files with:
# bun run docker:provision --admin-npub npub1...
# COMPOSE_PROJECT_NAME=wingman-01
# WINGMAN_INSTANCE_NAME=wingman-01
# WINGMAN_IMAGE=wingman-autopilot:local
# WINGMAN_HOST_PORT=3600
# WINGMAN_BASE_URL=http://localhost:3600
# WINGMAN_IDENTITY_COOKIE_SECURE=false
# WINGMAN_DIRECTORY_DEF=/workspace
# WINGMAN_FOLDERACCESS=/workspace
# WINGMAN_WORKSPACE_HOST_PATH=/Users/you/.wm-ap
# WINGMAN_APP_ROUTING=path
# WINGMAN_SUBDOMAIN_BASE_DOMAIN=
# WINGMAN_SUBDOMAIN_PROXY_ENABLED=true
# WINGMAN_DEFAULT_AGENT=codex
# WINGMAN_AGENT_SPAWN_MODE=bun
# WINGMAN_AGENTAPI_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
# WINGMAN_CODEX_CLI=/usr/local/bin/codex
# WINGMAN_CODEX_TRUSTED_WORKSPACE=/workspace
# WINGMAN_CLAUDE_CLI=/usr/local/bin/claude
# WINGMAN_GLOVES=OFF
# WINGMAN_GOOSE_CLI=/usr/local/bin/goose
# WINGMAN_OPENCODE_CLI=/usr/local/bin/opencode
# WINGMAN_IDENTITY_SESSION_SECRET=
# Required for Docker noninteractive setup; generated by docker:provision --admin-npub.
# WINGMAN_ADMIN_NPUB=npub1...
# Optional but recommended single Wingman instance private key.
# WINGMAN_PRIV=nsec1...
# Optional Key Teleport setup for Welcome.
# WINGMAN_KEYTELEPORT_PRIVKEY=nsec1...
# WINGMAN_KEYTELEPORT_WELCOME_PUBKEY=npub1...
# WINGMAN_KEYTELEPORT_WELCOME_URL=https://welcome.nostr.com
# WINGMAN_REGISTER=false
# WINGMAN_SHARED_INSTANCE=true
# Share Agent Dispatch workspace subscriptions, agents, and routes across approved users.
# Defaults to WINGMAN_SHARED_INSTANCE when unset.
# WINGMAN_SHARED_AGENT_DISPATCH=true
# Compatibility alias for older notes/scripts:
# WINGMAN_SEE_AGENT_SUBS=true
# WINGMAN_SETUP_NONINTERACTIVE=true
